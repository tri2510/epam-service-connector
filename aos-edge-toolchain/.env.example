# aos-edge-toolchain — Docker broadcaster environment
# Copy this file to .env and adjust values:
#   cp .env.example .env

# ──────────────────────────────────────────────
# Instance
# ──────────────────────────────────────────────
INSTANCE_ID=AET-TOOLCHAIN-001
INSTANCE_NAME=AOS Edge Toolchain
KIT_MANAGER_URL=https://kit.digitalauto.tech
BROADCAST_INTERVAL=30000

# ──────────────────────────────────────────────
# Certificate (pick ONE method)
# ──────────────────────────────────────────────

# Method 1: Local .p12 file (mount into container)
# The path below is the mount point INSIDE the container.
# Mount your host file to this path with -v:
#   -v $HOME/.aos/security/aos-user-sp.p12:/certs/aos-user-sp.p12:ro
CERT_FILE=/certs/aos-user-sp.p12

# Method 2: Azure Key Vault (production)
# Uncomment and set your vault name. Requires Azure Managed Identity.
# AZURE_KEY_VAULT_NAME=my-keyvault-name
# CERT_NAME=aos-user-sp

# ──────────────────────────────────────────────
# AosCloud (defaults for deployment status)
# ──────────────────────────────────────────────

# API base URL
AOSCLOUD_URL=https://aoscloud.io:10000

# Default service/unit/subject (used if not overridden from UI)
# SERVICE_UUID=c0528145-b393-44c6-aeaa-b26bc560acee
# UNIT_UID=8c85e914e91c4947be78f86889ca9444
# SUBJECT_ID=96d45a48-400d-4207-b67b-4665dce72a33

# ──────────────────────────────────────────────
# Network / Proxy
# ──────────────────────────────────────────────

# No proxy by default. Uncomment and set if behind a corporate proxy:
# https_proxy=http://127.0.0.1:3128
# http_proxy=http://127.0.0.1:3128

# Explicitly clear proxy (prevents inheriting host env vars)
HTTPS_PROXY=
HTTP_PROXY=
https_proxy=
http_proxy=

# Set to 0 only if corporate proxy does TLS interception
# NODE_TLS_REJECT_UNAUTHORIZED=0
