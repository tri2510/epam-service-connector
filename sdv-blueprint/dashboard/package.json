{
  "name": "sdv-blueprint-dashboard",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "./build.sh",
    "dev": "esbuild src/index.ts --bundle --format=iife --platform=browser --jsx=automatic --external:react --external:react-dom/client --external:react/jsx-runtime --sourcemap --outfile=index.js --watch=forever",
    "standalone": "esbuild src/standalone.ts --bundle --format=iife --platform=browser --jsx=automatic --sourcemap --outfile=standalone.js && echo 'Open standalone.html in a browser'",
    "standalone:dev": "esbuild src/standalone.ts --bundle --format=iife --platform=browser --jsx=automatic --sourcemap --outfile=standalone.js --servedir=. --serve=3012 --watch=forever"
  },
  "dependencies": {
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "esbuild": "^0.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.0.0"
  }
}
